<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/linear_editor_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app"
    android:padding="20dp">

    <!-- Top Info and Quick Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_worker_name"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Editing: Loading..."
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textSize="15sp"
            android:textColor="@color/text_primary_light"/>

        <TextView
            android:id="@+id/tv_copy_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy link"
            android:textStyle="bold"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:background="@drawable/bg_text_action"
            android:textColor="@color/cf_orange"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Code Editor Box -->
    <EditText
        android:id="@+id/et_code_editor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/bg_editor"
        android:gravity="top|start"
        android:elevation="2dp"
        android:hint="// Fetching script code from Cloudflare..."
        android:textColorHint="@color/text_secondary_light"
        android:inputType="textMultiLine|textNoSuggestions"
        android:padding="16dp"
        android:scrollbars="vertical|horizontal"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/text_primary_light" />

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btn_secrets"
            android:layout_width="0dp"
            android:layout_weight="1.2"
            android:layout_height="wrap_content"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:background="@drawable/bg_button_outline"
            android:text="Manage secrets"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/cf_orange"
            android:layout_marginEnd="10dp"/>

        <Button
            android:id="@+id/btn_deploy"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:background="@drawable/bg_button"
            android:text="Deploy"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/button_solid_text" />
    </LinearLayout>

</LinearLayout>
