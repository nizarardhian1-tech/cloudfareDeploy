<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator_editor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/header_bg"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_editor"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingTop="8dp"
            app:navigationIcon="@drawable/ic_theme"
            app:navigationIconTint="@color/text_on_header"
            app:title="Script Editor"
            app:titleTextColor="@color/text_on_header"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Body -->
    <LinearLayout
        android:id="@+id/linear_editor_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Worker info chip row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tv_worker_name"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Loading…"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textSize="15sp"
                android:textColor="@color/md_on_surface"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tv_copy_url"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy URL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/cf_orange"
                app:backgroundTint="@color/cf_orange_container"
                app:cornerRadius="10dp" />
        </LinearLayout>

        <!-- Code editor -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/md_outline_variant"
            app:cardBackgroundColor="@color/md_surface_container_low">

            <EditText
                android:id="@+id/et_code_editor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="top|start"
                android:hint="// Fetching script from Cloudflare…"
                android:textColorHint="@color/md_on_surface_variant"
                android:inputType="textMultiLine|textNoSuggestions"
                android:padding="16dp"
                android:scrollbars="vertical|horizontal"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/md_on_surface"
                android:textIsSelectable="true" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_secrets"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1.3"
                android:layout_height="wrap_content"
                android:text="Manage Secrets"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/cf_orange"
                app:strokeColor="@color/cf_orange"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp"
                android:layout_marginEnd="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_deploy"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Deploy"
                android:textAllCaps="false"
                android:textStyle="bold"
                app:backgroundTint="@color/cf_orange"
                app:cornerRadius="12dp"
                android:contentDescription="@string/content_desc_deploy_btn" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
