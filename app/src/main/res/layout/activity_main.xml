<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <!-- ─── HEADER ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="52dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Eyebrow label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLOUDFLARE MANAGER"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.14"
            android:textColor="@color/cf_orange"
            android:layout_marginBottom="8dp" />

        <!-- Account row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set up API Token"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="@color/text_on_header"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tv_subdomain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_on_header_sub"
                    android:visibility="gone" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tv_switch_account"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Switch"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/cf_orange"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:visibility="gone"
                app:strokeColor="@color/cf_orange"
                app:strokeWidth="1.5dp"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ─── SCROLLABLE BODY ──────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="170dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/linear_main_bg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp">

            <!-- ── Stats card (monitor) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_monitor"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="18dp">

                        <View
                            android:id="@+id/view_status_dot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/dot_status_offline"
                            android:contentDescription="@string/content_desc_status_dot" />

                        <TextView
                            android:id="@+id/tv_monitor_title"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Edge Monitor"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/md_on_surface" />
                    </LinearLayout>

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_label_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_api_status"
                                android:textSize="11sp"
                                android:textColor="@color/md_on_surface_variant" />
                            <TextView
                                android:id="@+id/tv_stat_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="Offline"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:textColor="@color/status_offline" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_label_limit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_request_limit"
                                android:textSize="11sp"
                                android:textColor="@color/md_on_surface_variant" />
                            <TextView
                                android:id="@+id/tv_stat_limit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="@string/request_limit"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:textColor="@color/md_on_surface" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_label_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_total_scripts"
                                android:textSize="11sp"
                                android:textColor="@color/md_on_surface_variant" />
                            <TextView
                                android:id="@+id/tv_stat_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="0"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                android:fontFamily="monospace"
                                android:textColor="@color/md_on_surface" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── KV / Licensing card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_database"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Title with accent bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_badge_accent" />

                        <TextView
                            android:id="@+id/tv_card_title_db"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="KV Database &amp; Licenses"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="@color/md_on_surface" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_card_desc_db"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Generate license keys, track registered devices, view geo log, and manage KV namespaces."
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/md_on_surface_variant"
                        android:layout_marginBottom="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_manage_licenses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manage Database &amp; Licenses"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="@color/cf_orange"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Workers / Scripts card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_workers"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Card header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:id="@+id/tv_card_title1"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Worker Scripts"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="@color/md_on_surface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/tv_create_worker_btn"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ New"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp"
                            app:backgroundTint="@color/md_secondary_container"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/tv_refresh_btn"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sync"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            app:backgroundTint="@color/md_surface_variant"
                            app:cornerRadius="10dp" />
                    </LinearLayout>

                    <!-- Search field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/md_outline_variant"
                        app:hintText="Search scripts…">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_search_worker"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:singleLine="true"
                            android:imeOptions="actionSearch"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Workers list -->
                    <LinearLayout
                        android:id="@+id/linear_workers_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_list_placeholder"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Set your Cloudflare API Token above to load edge scripts."
                            android:textSize="13sp"
                            android:gravity="center"
                            android:padding="28dp"
                            android:lineSpacingExtra="4dp"
                            android:textColor="@color/md_on_surface_variant" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ─── SNACKBAR ANCHOR ──────────────────────────────────── -->
    <View
        android:id="@+id/snackbar_anchor"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="16dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
