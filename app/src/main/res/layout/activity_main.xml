<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/linear_main_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Top Dashboard Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/colorPrimary">

        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLOUDEP EDGE CONSOLE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#EAEAEA" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_account"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tap to Setup Token ⚙️"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_switch_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 Akun"
                android:textStyle="bold"
                android:textSize="12sp"
                android:padding="8dp"
                android:background="#33FFFFFF"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_subdomain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subdomain: Loading..."
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:textColor="#F5F5F5"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Monitoring -->
            <LinearLayout
                android:id="@+id/card_monitor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_editor">

                <TextView
                    android:id="@+id/tv_monitor_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edge Monitor &amp; Stats 📈"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary_light"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_label_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="API Status"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary_light"/>
                        <TextView
                            android:id="@+id/tv_stat_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Offline"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#FF4444"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_label_limit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Request Limit"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary_light"/>
                        <TextView
                            android:id="@+id/tv_stat_limit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100k / Day"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary_light"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_label_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Scripts"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary_light"/>
                        <TextView
                            android:id="@+id/tv_stat_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary_light"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Card: Database -->
            <LinearLayout
                android:id="@+id/card_database"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_editor">

                <TextView
                    android:id="@+id/tv_card_title_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Licensing &amp; Key Database 🔑"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_light"/>

                <TextView
                    android:id="@+id/tv_card_desc_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate license keys, track registered devices, view user GEO log, and manage KV database."
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary_light"/>

                <Button
                    android:id="@+id/btn_manage_licenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button"
                    android:text="Manage Database &amp; Licenses"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Card: Workers -->
            <LinearLayout
                android:id="@+id/card_workers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_editor">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_card_title1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Repository / Scripts 📦"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary_light"/>

                    <TextView
                        android:id="@+id/tv_create_worker_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="➕ New"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:padding="6dp"
                        android:layout_marginRight="8dp"
                        android:textColor="@color/cf_orange"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tv_refresh_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄 Sync"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:padding="6dp"
                        android:textColor="@color/cf_orange"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- SEARCH BAR (FIXED - hintTextColor dihapus) -->
                <EditText
                    android:id="@+id/et_search_worker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="🔍 Cari script..."
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:background="@drawable/bg_editor"
                    android:padding="10dp"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/text_primary_light"/>

                <LinearLayout
                    android:id="@+id/linear_workers_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_list_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Configure your API token above to load your edge scripts."
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="24dp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/text_secondary_light"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>