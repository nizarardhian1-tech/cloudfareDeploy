<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/linear_main_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app">

    <!-- Top Dashboard Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="22dp"
        android:background="@drawable/bg_header">

        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLOUDEP EDGE CONSOLE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:textColor="@color/cf_orange" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_account"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tap to setup token"
                android:textStyle="bold"
                android:textSize="19sp"
                android:textColor="@color/text_on_header" />

            <TextView
                android:id="@+id/tv_switch_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Switch"
                android:textStyle="bold"
                android:textSize="12sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@drawable/bg_button_outline"
                android:textColor="@color/cf_orange"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_subdomain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subdomain: Loading..."
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_on_header_secondary"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Monitoring -->
            <LinearLayout
                android:id="@+id/card_monitor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/dot_status_offline" />

                    <TextView
                        android:id="@+id/tv_monitor_title"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Edge monitor &amp; stats"
                        style="@style/Label.Section" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_label_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="API status"
                            style="@style/Label.Caption" />
                        <TextView
                            android:id="@+id/tv_stat_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Offline"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/status_offline"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_label_limit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Request limit"
                            style="@style/Label.Caption" />
                        <TextView
                            android:id="@+id/tv_stat_limit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="100k / day"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            style="@style/Text.Mono"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_label_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total scripts"
                            style="@style/Label.Caption" />
                        <TextView
                            android:id="@+id/tv_stat_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            style="@style/Text.Mono"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Card: Database -->
            <LinearLayout
                android:id="@+id/card_database"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:id="@+id/tv_card_title_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Licensing &amp; key database"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_light"/>

                <TextView
                    android:id="@+id/tv_card_desc_db"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate license keys, track registered devices, view user GEO log, and manage KV database."
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary_light"/>

                <Button
                    android:id="@+id/btn_manage_licenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@drawable/bg_button"
                    android:text="Manage database &amp; licenses"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/text_on_accent" />
            </LinearLayout>

            <!-- Card: Workers -->
            <LinearLayout
                android:id="@+id/card_workers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/tv_card_title1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Repository / scripts"
                        style="@style/Label.Section" />

                    <TextView
                        android:id="@+id/tv_create_worker_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ New"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_text_action"
                        android:textColor="@color/cf_orange"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tv_refresh_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sync"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/bg_text_action"
                        android:textColor="@color/cf_orange"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/et_search_worker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Cari script..."
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:background="@drawable/bg_editor"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="12dp"
                    android:textColorHint="@color/text_secondary_light"
                    android:textColor="@color/text_primary_light"/>

                <LinearLayout
                    android:id="@+id/linear_workers_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_list_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Configure your API token above to load your edge scripts."
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="24dp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/text_secondary_light"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
