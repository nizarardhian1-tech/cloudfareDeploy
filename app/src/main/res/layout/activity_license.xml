<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/linear_license_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app"
    android:padding="20dp">

    <!-- Database KV Setup Bar -->
    <LinearLayout
        android:id="@+id/card_kv_setup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:elevation="3dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_card">

        <TextView
            android:id="@+id/tv_kv_namespace_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Database KV namespace ID"
            style="@style/Label.Section"
            android:textSize="12sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="9dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_kv_namespace_id"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tap to set KV Namespace ID..."
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textColor="@color/cf_orange"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_create_namespace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:background="@drawable/bg_button_outline"
            android:text="Create KV namespace"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="@color/cf_orange"/>
    </LinearLayout>

    <!-- Two Tab Buttons (segmented control) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="18dp">

        <Button
            android:id="@+id/btn_tab_keys"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:background="@drawable/bg_tab_active"
            android:text="Keys list"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#0B0F17"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btn_tab_logs"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:background="@drawable/bg_tab_inactive"
            android:text="GEO access logs"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="@color/text_secondary_light"
            android:layout_marginStart="5dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tab 1: Keys Container -->
            <LinearLayout
                android:id="@+id/layout_tab_keys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <Button
                    android:id="@+id/btn_generate_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:background="@drawable/bg_button"
                    android:text="Generate license key"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/button_solid_text"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:id="@+id/container_keys_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:elevation="3dp"
                    android:background="@drawable/bg_card"
                    android:layout_marginBottom="18dp">

                    <TextView
                        android:id="@+id/tv_keys_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No keys loaded. Set Namespace ID above."
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="22dp"
                        android:textColor="@color/text_secondary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tab 2: Logs Container -->
            <LinearLayout
                android:id="@+id/layout_tab_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/container_logs_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:elevation="3dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_card">

                    <TextView
                        android:id="@+id/tv_logs_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No login logs collected yet."
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="22dp"
                        android:textColor="@color/text_secondary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Card: API Handshake Simulator -->
            <LinearLayout
                android:id="@+id/card_simulator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:elevation="3dp"
                android:background="@drawable/bg_card">

                <TextView
                    android:id="@+id/tv_simulator_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API handshake simulator"
                    style="@style/Label.Section"/>

                <TextView
                    android:id="@+id/tv_simulator_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Simulate a validation check from your APK to test your script's integration."
                    android:textSize="11sp"
                    android:layout_marginTop="5dp"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/text_secondary_light"/>

                <EditText
                    android:id="@+id/et_sim_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="https://your-worker-url.workers.dev"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:singleLine="true"
                    android:background="@drawable/bg_editor"
                    android:textColorHint="@color/text_secondary_light"
                    android:textColor="@color/text_primary_light"
                    android:padding="13dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="11dp">

                    <EditText
                        android:id="@+id/et_sim_key"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="License key"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:background="@drawable/bg_editor"
                        android:textColorHint="@color/text_secondary_light"
                        android:textColor="@color/text_primary_light"
                        android:padding="13dp"
                        android:layout_marginEnd="7dp"/>

                    <EditText
                        android:id="@+id/et_sim_device"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Device ID"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:background="@drawable/bg_editor"
                        android:textColorHint="@color/text_secondary_light"
                        android:textColor="@color/text_primary_light"
                        android:padding="13dp"
                        android:layout_marginStart="7dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_run_sim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:background="@drawable/bg_button"
                    android:text="Run validation check"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="@color/button_solid_text"/>

                <TextView
                    android:id="@+id/tv_sim_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Response output: waiting for simulation run..."
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary_light"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:background="@drawable/bg_editor"
                    android:padding="13dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
