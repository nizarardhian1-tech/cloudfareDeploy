<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/linear_license_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light"
    android:padding="16dp">

    <!-- Database KV Setup Bar -->
    <LinearLayout
        android:id="@+id/card_kv_setup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_editor">

        <TextView
            android:id="@+id/tv_kv_namespace_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Database KV Namespace ID ⚙️"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="@color/text_primary_light"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_kv_namespace_id"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tap to set KV Namespace ID..."
                android:textSize="13sp"
                android:textColor="@color/cf_orange"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_create_namespace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button"
            android:text="Create KV Namespace ➕"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Two Tab Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btn_tab_keys"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button"
            android:text="Keys List 🔑"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginRight="4dp"/>

        <Button
            android:id="@+id/btn_tab_logs"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button"
            android:text="GEO Access Logs 📈"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tab 1: Keys Container -->
            <LinearLayout
                android:id="@+id/layout_tab_keys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <Button
                    android:id="@+id/btn_generate_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_button"
                    android:text="Generate License Key ➕"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:id="@+id/container_keys_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:background="@drawable/bg_editor"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tv_keys_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No keys loaded. Set Namespace ID above."
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="20dp"
                        android:textColor="@color/text_secondary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tab 2: Logs Container -->
            <LinearLayout
                android:id="@+id/layout_tab_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/container_logs_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_editor">

                    <TextView
                        android:id="@+id/tv_logs_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No login logs collected yet."
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="20dp"
                        android:textColor="@color/text_secondary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Card: API Handshake Simulator -->
            <LinearLayout
                android:id="@+id/card_simulator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_editor">

                <TextView
                    android:id="@+id/tv_simulator_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API Handshake Simulator 🧪"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary_light"/>

                <TextView
                    android:id="@+id/tv_simulator_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Simulate a validation check from your APK to test your script's integration."
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary_light"/>

                <EditText
                    android:id="@+id/et_sim_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="https://your-worker-url.workers.dev"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:background="@drawable/bg_editor"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/et_sim_key"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="License Key (e.g. KEY-A1)"
                        android:textSize="13sp"
                        android:singleLine="true"
                        android:background="@drawable/bg_editor"
                        android:padding="8dp"
                        android:layout_marginRight="4dp"/>

                    <EditText
                        android:id="@+id/et_sim_device"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="Device ID (simulated)"
                        android:textSize="13sp"
                        android:singleLine="true"
                        android:background="@drawable/bg_editor"
                        android:padding="8dp"
                        android:layout_marginLeft="4dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_run_sim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button"
                    android:text="Run Validation Check 🚀"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tv_sim_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Response Output: Waiting for simulation run..."
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary_light"
                    android:fontFamily="monospace"
                    android:background="#0D000000"
                    android:padding="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>