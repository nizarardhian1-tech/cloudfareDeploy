<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator_license"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/header_bg">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_license"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingTop="8dp"
            app:navigationIcon="@drawable/ic_theme"
            app:navigationIconTint="@color/text_on_header"
            app:titleTextColor="@color/text_on_header" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/linear_license_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── KV Setup Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_kv_setup"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_badge_accent" />

                        <TextView
                            android:id="@+id/tv_kv_namespace_label"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="KV Namespace"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="@color/md_on_surface" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_kv_namespace_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tap to set KV Namespace ID…"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/cf_orange"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="12dp"
                        android:background="@drawable/bg_editor"
                        android:layout_marginBottom="14dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_create_namespace"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Create New"
                            android:textAllCaps="false"
                            android:textColor="@color/cf_orange"
                            app:strokeColor="@color/cf_orange"
                            app:cornerRadius="12dp"
                            android:layout_marginEnd="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_generate_key"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Generate Key"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/cf_orange"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Keys / Logs Tabs Card ── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Tab row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_editor"
                        android:padding="4dp"
                        android:layout_marginBottom="14dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_tab_keys"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Keys"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_tab_active"
                            app:rippleColor="@android:color/transparent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_tab_logs"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Logs"
                            android:textAllCaps="false"
                            android:textStyle="bold"
                            android:textColor="@color/md_on_surface_variant"
                            android:background="@drawable/bg_tab_inactive"
                            app:rippleColor="@android:color/transparent" />
                    </LinearLayout>

                    <!-- Keys tab content -->
                    <LinearLayout
                        android:id="@+id/layout_tab_keys"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <LinearLayout
                            android:id="@+id/container_keys_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_keys_placeholder"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="No license keys found. Set namespace and generate a key."
                                android:gravity="center"
                                android:padding="24dp"
                                android:textSize="13sp"
                                android:textColor="@color/md_on_surface_variant"
                                android:visibility="visible" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Logs tab content -->
                    <LinearLayout
                        android:id="@+id/layout_tab_logs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/container_logs_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_logs_placeholder"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tap a key in 'Keys' tab to view geo stats."
                                android:gravity="center"
                                android:padding="24dp"
                                android:textSize="13sp"
                                android:textColor="@color/md_on_surface_variant" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── API Simulator Card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_simulator"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_outline_variant"
                app:cardBackgroundColor="@color/md_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_simulator_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="API Verification Simulator"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/md_on_surface"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_simulator_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Test your Worker's /check endpoint with a key and device ID."
                        android:textSize="13sp"
                        android:textColor="@color/md_on_surface_variant"
                        android:layout_marginBottom="14dp"
                        android:lineSpacingExtra="2dp" />

                    <EditText
                        android:id="@+id/et_sim_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Worker URL"
                        android:singleLine="true"
                        android:background="@drawable/bg_editor"
                        android:padding="12dp"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/md_on_surface"
                        android:textColorHint="@color/md_on_surface_variant" />

                    <EditText
                        android:id="@+id/et_sim_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="License key"
                        android:singleLine="true"
                        android:background="@drawable/bg_editor"
                        android:padding="12dp"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/md_on_surface"
                        android:textColorHint="@color/md_on_surface_variant" />

                    <EditText
                        android:id="@+id/et_sim_device"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Device ID"
                        android:singleLine="true"
                        android:background="@drawable/bg_editor"
                        android:padding="12dp"
                        android:textSize="13sp"
                        android:layout_marginBottom="14dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/md_on_surface"
                        android:textColorHint="@color/md_on_surface_variant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_run_sim"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Run Simulation"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:backgroundTint="@color/md_primary"
                        app:cornerRadius="12dp"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:id="@+id/tv_sim_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/md_on_surface_variant"
                        android:background="@drawable/bg_editor"
                        android:padding="12dp"
                        android:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
